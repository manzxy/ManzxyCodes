{
  "name": "manzxycodes",
  "version": "1.0.0",
  "description": "ManzxyCodes Platform snippet code by Manzxy",
  "private": true,
  "type": "module",
  "main": "manzxy.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node manzxy.js",
    "dev": "node --watch manzxy.js",
    "pm2": "pm2 start manzxy.js --name manzxycodes",
    "pm2:stop": "pm2 stop manzxycodes",
    "pm2:log": "pm2 logs manzxycodes",
    "install:vps": "npm ci --omit=dev",
    "start:prod": "NODE_ENV=production node manzxy.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^5.9.6"
  }
}
