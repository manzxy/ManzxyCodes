#
# CARA PAKAI:
#   1. Copy/rename file ini menjadi ".env" (hapus .example)
#   2. Isi bagian SUPABASE (3 baris) — ambil dari Supabase Dashboard
#   3. Isi ADMIN_USERNAME & ganti ADMIN_PASSWORD di SETUP.md
#   4. Jangan pernah commit file .env ke Git!
#
# ════════════════════════════════════════════════════════════════
# SERVER
# ════════════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=production

# Domain kamu — dipakai untuk CORS whitelist
# Ganti dengan domain aktif, misal: https://manzxy.biz.id
DOMAIN=https://manzxy.biz.id

# ════════════════════════════════════════════════════════════════
# SUPABASE  ← WAJIB DIISI
# Ambil dari: supabase.com → Project → Settings → API
# ════════════════════════════════════════════════════════════════

# Project URL (contoh: https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://nnwcexdhvxqcjjewkblt.supabase.co

# anon/public key — boleh publik, untuk SELECT
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ud2NleGRodnhxY2pqZXdrYmx0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM3NzY2MTUsImV4cCI6MjA4OTM1MjYxNX0.rAYcFyjsrW7JPLenC9ZDtCPLE3CuflAAhZtyTokFL7c.XXXXXXXX

# service_role key — RAHASIA, untuk INSERT/UPDATE/DELETE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ud2NleGRodnhxY2pqZXdrYmx0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mzc3NjYxNSwiZXhwIjoyMDg5MzUyNjE1fQ.m0wxZZcPYABah_PjMjca40VQ3nF01xluWpCo4hY7-sM

# ════════════════════════════════════════════════════════════════
# ADMIN LOGIN
# ════════════════════════════════════════════════════════════════

# Username untuk login admin di /app
ADMIN_USERNAME=manzxy

# Hash SHA-256 dari password admin
# Password default: ManzxyAdmin2026!
# ⚠️  GANTI PASSWORD SEBELUM DEPLOY — lihat cara generate di bawah
# Untuk generate hash baru jalankan di terminal:
#   node -e "const c=require('crypto');const salt='Os=cJ-f77K#IY*_Lqo3lde2abOQdVCad';const h=c.createHash('sha256').update('PASSWORD_BARU'+salt).digest('hex');console.log(h)"
ADMIN_PASSWORD_HASH=f87049312919e026446b07e98421b0fe29fbe1fd3cffb4f85abe7d1c88583766

# Salt untuk hashing password (JANGAN DIUBAH setelah deploy)
# Sudah di-generate otomatis — simpan baik-baik!
PASSWORD_SALT=Os=cJ-f77K#IY*_Lqo3lde2abOQdVCad

# ════════════════════════════════════════════════════════════════
# JWT SESSION
# ════════════════════════════════════════════════════════════════

# Secret key untuk sign JWT session admin (min 32 karakter)
# Sudah di-generate otomatis — JANGAN DIUBAH setelah deploy
# (mengubah ini akan logout semua admin session yang aktif)
JWT_SECRET=aDCBzrO=boK2Wn5AA9#NUuqQoHFKmnJ4MtI^nTaXlIi*T9jK

# ════════════════════════════════════════════════════════════════
# SNIPPET KEY
# ════════════════════════════════════════════════════════════════

# Salt untuk hashing snippet key (key yang user pakai untuk edit/hapus snippet)
# Sudah di-generate otomatis — JANGAN DIUBAH setelah deploy
# (mengubah ini akan membuat semua snippet key lama tidak valid)
KEY_SALT=PLkVXRZi_cQcn7!VPc-c*0@huHgV+Ozx

# ════════════════════════════════════════════════════════════════
# NOTES
# ════════════════════════════════════════════════════════════════
#
# ✅ Yang perlu kamu isi:
#    - SUPABASE_URL          ← dari Supabase dashboard
#    - SUPABASE_ANON_KEY     ← dari Supabase dashboard
#    - SUPABASE_SERVICE_ROLE_KEY ← dari Supabase dashboard
#    - ADMIN_USERNAME        ← bebas, default: manzxy
#    - DOMAIN                ← domain kamu
#
# ✅ Yang sudah otomatis (tidak perlu diubah):
#    - ADMIN_PASSWORD_HASH   ← hash dari password default di atas
#    - PASSWORD_SALT         ← random, sudah di-generate
#    - JWT_SECRET            ← random, sudah di-generate
#    - KEY_SALT              ← random, sudah di-generate
#    - PORT                  ← default 3000
#    - NODE_ENV              ← default production
#
# ⚠️  Password admin default: ManzxyAdmin2026!
# ⚠️  GANTI PASSWORD SEGERA setelah pertama login!
#     Cara generate hash password baru:
#     node -e "const c=require('crypto');const h=c.createHash('sha256').update('PASSWORD_BARU'+process.env.PASSWORD_SALT).digest('hex');console.log(h)"
#     Lalu update ADMIN_PASSWORD_HASH di .env ini
