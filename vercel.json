{
  "version": 2,
  "functions": {
    "api/**/*.js": { "memory": 128, "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/info",     "dest": "/info.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/(.*)",    "dest": "/index.html" }
  ]
}
