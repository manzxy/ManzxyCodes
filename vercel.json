{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/info.html",
      "status": 301,
      "headers": {
        "Location": "/info"
      }
    },
    {
      "src": "/index.html",
      "status": 301,
      "headers": {
        "Location": "/app"
      }
    },
    {
      "src": "/",
      "dest": "/info.html"
    },
    {
      "src": "/info",
      "dest": "/info.html"
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)\\.js",
      "dest": "/$1.js"
    },
    {
      "src": "/(.*)\\.css",
      "dest": "/$1.css"
    },
    {
      "src": "/(.*)\\.woff2",
      "dest": "/$1.woff2"
    },
    {
      "src": "/(.*)",
      "dest": "/info.html"
    }
  ]
}