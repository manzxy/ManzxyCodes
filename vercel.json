{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/info.html", "destination": "/info.html" },
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/app",        "destination": "/index.html" },
    { "source": "/app/(.*)",   "destination": "/index.html" },
    { "source": "/info",       "destination": "/info.html" },
    { "source": "/",           "destination": "/info.html" },
    { "source": "/(.*)",       "destination": "/info.html" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/app",  "permanent": true },
    { "source": "/info.html",  "destination": "/info", "permanent": true }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
